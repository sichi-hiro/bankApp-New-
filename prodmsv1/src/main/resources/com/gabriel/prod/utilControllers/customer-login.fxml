<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f4f7f9;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.prod.utilControllers.CustomerLoginController">

    <top>
        <VBox alignment="CENTER" prefHeight="120.0" style="-fx-background-color: #1b6b80;" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #ffffff;" text="BANKING APP" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #e8f2f5;" text="Secure Customer Access Gateway" />
            </children>
        </VBox>
    </top>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" maxWidth="400.0" prefWidth="400.0" spacing="25.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #f1f3f5; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 20, 0, 0, 8);">                    <padding>
                        <Insets bottom="40.0" left="30.0" right="30.0" top="40.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #495057;" text="Enter Your Account Information" />

                        <VBox spacing="8.0" fillWidth="true">
                            <children>
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6c757d;" text="ACCOUNT NUMBER" />
                                <TextField fx:id="txtAccountNumber" prefHeight="40.0" promptText="e.g. 1002003405" style="-fx-font-size: 14px; -fx-background-radius: 4px;" />
                            </children>
                        </VBox>

                        <Label fx:id="lblError" managed="false" visible="false" style="-fx-text-fill: #fa5252; -fx-font-size: 13px; -fx-font-weight: bold;" text="Invalid Account Number. Please try again." wrapText="true" />

                        <HBox alignment="CENTER" spacing="15.0" style="-fx-margin-top: 10px;">
                            <children>
                                <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#onCancel" prefHeight="38.0" prefWidth="120.0" style="-fx-font-size: 13px;" text="Back" />
                                <Button fx:id="btnVerify" styleClass="button-primary" mnemonicParsing="false" onAction="#onVerifyAccount" prefHeight="38.0" prefWidth="160.0" style="-fx-font-size: 13px; -fx-font-weight: bold;" text="Verify Account" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>