<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="25.0" style="-fx-background-color: #f4f7f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.prod.utilControllers.RoleSelectionController">
    <children>

        <VBox alignment="CENTER" spacing="5.0">
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1b6b80;" text="Banking App" />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #495057;" text="Please choose your access portal to continue" />
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="40.0">
            <children>

                <VBox alignment="CENTER" onMouseClicked="#onAdminSelected" prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #e9ecef; -fx-border-radius: 12px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 40px;" text="⚙️" />
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1b6b80;" text="System Admin">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Label>
                        <Label alignment="CENTER" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" text="Manage accounts, modify files, and run audits.">
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" onMouseClicked="#onCustomerSelected" prefHeight="180.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-border-color: #e9ecef; -fx-border-radius: 12px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 40px;" text="👤" />
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1b6b80;" text="Bank Customer">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Label>
                        <Label alignment="CENTER" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" text="Check balances, make deposits, and withdraw funds.">
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

            </children>
        </HBox>

    </children>
</VBox>