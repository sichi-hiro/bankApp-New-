<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="prodman" prefHeight="575.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.prod.utilControllers.ProdManController">

    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#onCreate" text="Open Account" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#onClose" text="Exit System" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#onUpdate" text="Edit Account" />
                        <MenuItem mnemonicParsing="false" onAction="#onDelete" text="Close Account" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#onAbout" text="About" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <left>
        <VBox spacing="15.0" style="-fx-background-color: #1b6b80; -fx-padding: 25px 20px 25px 20px;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../../images/ItemSpecifications.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #ffffff;" text="Accounts Directory" />
                <ListView fx:id="lvProducts" onMouseClicked="#onMouseClicked" prefHeight="310.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="12.0" style="-fx-padding: 20px 25px 20px 20px; -fx-background-color: #f4f7f9;" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #495057;" text="Account Specifications" />

                <VBox style="-fx-border-color: #e9ecef; -fx-border-width: 1px; -fx-border-radius: 8px; -fx-background-color: #ffffff; -fx-background-radius: 8px;" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <GridPane hgap="15.0" vgap="18.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="130.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                            </columnConstraints>
                            <children>
                                <Label style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Account Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="tfId" maxWidth="125.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Account Holder:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="tfName" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Account Type:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <TextField fx:id="tfDesc" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <!-- UPDATED: Relabeled to accurately reflect Currency Profile (PHP) -->
                                <Label style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Currency Profile:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                <TextField fx:id="tfUom" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <!-- NEW ROW: Dedicated field for the true numeric transaction balance -->
                                <Label style="-fx-text-fill: #495057; -fx-font-weight: bold;" text="Account Balance (₱):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                <TextField fx:id="tfBalance" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                        </GridPane>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="12.0">
                    <children>
                        <Button fx:id="createButton" styleClass="button-primary" mnemonicParsing="false" onAction="#onCreate" prefWidth="110.0" text="Open Account" />
                        <Button fx:id="updateButton" styleClass="button-primary" mnemonicParsing="false" onAction="#onUpdate" prefWidth="110.0" text="Edit Account" />
                        <Button fx:id="deleteButton" styleClass="button-primary" onAction="#onDelete" prefWidth="110.0" text="Close Account" />
                        <Button fx:id="closeButton" onAction="#onClose" prefWidth="85.0" text="Close" />
                    </children>
                    <VBox.margin>
                        <Insets bottom="5.0" top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>